<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFBFC"> <LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:padding="32dp">

    <ImageView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/bg_circle_alert"
        android:padding="20dp"
        android:src="@android:drawable/ic_dialog_info" app:tint="#FFB300" /> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="24dp"
    android:text="Alerts"
    android:textColor="#232D42"
    android:textSize="22sp"
    android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Уведомления и оповещения появятся здесь"
        android:textAlignment="center"
        android:textColor="#8A92A6"
        android:textSize="14sp" />

</LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>